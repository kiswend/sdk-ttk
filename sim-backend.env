# Enable mutual TLS authentication
MUTUAL_TLS_ENABLED=false

# Enable server-only TLS
HTTPS_ENABLED=false

# Location of certs and key required for TLS
CA_CERT_PATH=./secrets/cacert.pem
SERVER_CERT_PATH=./secrets/servercert.pem
SERVER_KEY_PATH=./secrets/serverkey.pem

# Log indentation (0 = single line)
LOG_INDENT=0

# In-memory sqlite log
SQLITE_LOG_FILE=:memory:

# The DFSPID of this simulator
DFSP_ID=itk-load-test-dfsp

# In-memory model database
MODEL_DATABASE=:memory:

# Outbound API endpoint (SDK scheme adapter outbound port)
OUTBOUND_ENDPOINT=http://mojaloop-connector-load-test:4001

# Fee multiplier for quote responses (5%)
FEE_MULTIPLIER=0.05

# Rules file location
RULES_FILE=../rules/rules.json

# Ports
SIMULATOR_API_LISTEN_PORT=3000
REPORT_API_LISTEN_PORT=3002
TEST_API_LISTEN_PORT=3003
